# LLM provider — pick ONE of openai (default) or anthropic
LLM_PROVIDER=openai

# OpenAI (default)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini      # or gpt-4o for richer "why this matters" lines

# Anthropic (only if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-5

# Mail provider (used for both SMTP send and IMAP feedback ingest)
# Defaults are Gmail; for Gmail you need a 16-char App Password (see README).
MAIL_USER=dejan.krstic2709@gmail.com
MAIL_PASS=your-16-char-app-password
MAIL_SMTP_HOST=smtp.gmail.com
MAIL_SMTP_PORT=465
MAIL_IMAP_HOST=imap.gmail.com
MAIL_IMAP_PORT=993

# Recipients & sender display
DIGEST_TO=dejan.krstic2709@gmail.com
DIGEST_FROM_NAME=AI News Feed
FEEDBACK_TO=dejan.krstic2709@gmail.com

# Behavior
MAX_ITEMS=6
DIGEST_DRY_RUN=false
